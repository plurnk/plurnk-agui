{
    "compilerOptions": {
        "target": "es2024",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "test/**/*.ts"]
}
