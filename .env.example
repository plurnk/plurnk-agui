# @plurnk/plurnk-agui — the daemon's transport daughter.
#
# IN-PROCESS (the real deployment): the daemon's composition root reads the surface
# vars and hands them to Module.init — plurnk's ONE client surface:
#   PLURNK_HOST / PLURNK_PORT      the AG-UI+ listener (the daemon's own legend)
#   PLURNK_AGUI_SESSION_PREFIX     session name prefix: <prefix>-<threadId>
#   PLURNK_AGUI_TOKEN              bearer for the module's edge authz (empty = loopback trust)
#   PLURNK_AGUI_MAX_TURNS          per-run turn cap default
# Those are documented authoritatively in plurnk-service/.env.example; the module owns
# their semantics, the daemon owns the read.

# --- LEGACY standalone bridge (retires at cutover; its own env story) ---
PLURNK_AGUI_DAEMON_URL=ws://127.0.0.1:3044
PLURNK_AGUI_HOST=127.0.0.1
PLURNK_AGUI_PORT=3080
PLURNK_AGUI_SESSION_PREFIX=agui
PLURNK_AGUI_QUESTIONS=1
PLURNK_AGUI_YOLO=0
PLURNK_AGUI_MAX_TURNS=24
PLURNK_AGUI_TOKEN=
